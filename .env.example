# AI DevOps Team environment configuration
# Copy this file to .env and populate the values.

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT=10
LOCAL_LLM_MODEL=gpt2
LOCAL_LLM_URL=http://127.0.0.1:8000/v1/chat/completions
LOCAL_LLM_DEVICE=cpu

GITHUB_TOKEN=
GITHUB_REPO=owner/repo

KUBERNETES_KUBECONFIG=
KUBERNETES_NAMESPACE=default
AWS_REGION=

PROMETHEUS_URL=
GRAFANA_URL=
GRAFANA_API_KEY=

SLACK_TOKEN=
SLACK_CHANNEL=

DATABASE_URL=
REDIS_URL=

ENV=development
DEBUG=true
CORS_ORIGINS=*
